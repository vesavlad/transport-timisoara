# Vendor API base URL (example)
VITE_TRANSIT_API_BASE_URL=https://api.your-transit-provider.com

# Vendor API key/token (if required)
VITE_TRANSIT_API_KEY=REPLACE_ME

# --- STPT live config (optional) ---
# If set, the app will use STPT `lines-config.json` as its source for routes/shapes/stops.
#
# Tip (dev): if the direct URL is blocked by CORS, use the Vite proxy instead:
#   VITE_LINES_CONFIG_URL=/stpt/lines-config.json
VITE_LINES_CONFIG_URL=https://live.stpt.ro/lines-config.json

# How often to refetch the lines config (milliseconds). Default: 15 minutes.
VITE_LINES_CONFIG_REFETCH_MS=900000

# STPT live vehicles feed (status + location)
# Tip (dev): if direct URL is blocked by CORS, use:
#   VITE_STPT_VEHICLES_URL=/stpt/gtfs-vehicles.php
VITE_STPT_VEHICLES_URL=https://live.stpt.ro/gtfs-vehicles.php

# --- Map basemap style (optional) ---
# MapLibre style JSON URL.
# Default (if unset): CARTO Voyager (OSM-based)
#   https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json
# Other examples:
#   https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
#   https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
# VITE_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json
